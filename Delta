-- LOGIC SEARCH (DARI SCRIPTBLOX) 🕵️‍♂️
S_Input.FocusLost:Connect(function(enter)
    if enter then
        for _, v in pairs(S_Scroll:GetChildren()) do v:Destroy() end -- Bersihin list lama
        local query = S_Input.Text
        local url = "https://scriptblox.com/api/script/search?q=" .. query .. "&mode=free"
        
        local success, res = pcall(function()
            return game:HttpGet(url)
        end)
        
        if success then
            local data = game:GetService("HttpService"):JSONDecode(res)
            local yPos = 0
            for i, scriptData in pairs(data.result.scripts) do
                local sBtn = Instance.new("TextButton")
                sBtn.Parent = S_Scroll
                sBtn.Text = scriptData.title
                sBtn.Size = UDim2.new(0.95, 0, 0, 30)
                sBtn.Position = UDim2.new(0, 0, 0, yPos)
                sBtn.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
                sBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
                yPos = yPos + 35
                
                sBtn.MouseButton1Click:Connect(function()
                    Editor.Text = scriptData.script -- Copy script ke editor
                    ExecPage.Visible = true
                    SearchPage.Visible = false
                    print("Script Loaded to Editor!")
                end)
            end
        end
    end
end)

-- [GENERAL LOGIC]
ClearBtn.MouseButton1Click:Connect(function() Editor.Text = "" end) -- Clear Logic

